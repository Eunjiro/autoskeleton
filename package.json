{
  "name": "@gyojiro/autoskeleton-react",
  "version": "0.1.6",
  "description": "Beautiful, composable loading skeletons for React.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/index.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "keywords": [
    "react",
    "skeleton",
    "loading",
    "placeholder",
    "typescript",
    "ui",
    "component-library"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run src/test",
    "test:watch": "vitest src/test",
    "test:coverage": "vitest run src/test --coverage",
    "test:storybook": "vitest run --project=storybook",
    "prepublishOnly": "npm run build",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "rollup-plugin-dts": "^6.4.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.1",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.10",
    "storybook": "^10.5.2",
    "@storybook/react-vite": "^10.5.2",
    "@chromatic-com/storybook": "^5.2.1",
    "@storybook/addon-vitest": "^10.5.2",
    "@storybook/addon-a11y": "^10.5.2",
    "@storybook/addon-docs": "^10.5.2",
    "@storybook/addon-mcp": "^0.7.0",
    "eslint-plugin-storybook": "^10.5.2",
    "@vitest/browser-playwright": "4.1.10",
    "playwright": "^1.61.1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eunjiro/autoskeleton.git"
  },
  "bugs": {
    "url": "https://github.com/Eunjiro/autoskeleton/issues"
  },
  "homepage": "https://github.com/Eunjiro/autoskeleton#readme"
}
